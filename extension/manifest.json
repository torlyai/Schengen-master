{
  "manifest_version": 3,
  "name": "Visa Master — Schengen Visa Slot Watcher (TLScontact)",
  "short_name": "Visa Master",
  "version": "1.1.0",
  "description": "Stop refreshing TLScontact. Get a phone + desktop ping the second a Schengen visa slot opens. Local-only, no servers.",
  "homepage_url": "https://github.com/torlyai/Schengen-master",
  "author": "Torly AI",
  "minimum_chrome_version": "110",

  "action": {
    "default_title": "Visa Master — Schengen Visa Slot Watcher",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  },

  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },

  "options_page": "src/settings/settings.html",

  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*.tlscontact.com/*"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "https://torly.ai/visa-master/activated*",
        "https://*.torly.ai/visa-master/activated*"
      ],
      "js": ["src/content/license-relay.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "https://*.tlscontact.com/*",
    "https://torly.ai/*",
    "https://*.torly.ai/*"
  ],

  "optional_host_permissions": [
    "https://api.github.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "src/welcome/welcome.html",
        "src/settings/settings.html",
        "src/premium/premium.html",
        "public/icons/*",
        "qrcode/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
